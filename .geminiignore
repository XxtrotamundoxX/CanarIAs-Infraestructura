# Bloquear el núcleo de WordPress (miles de archivos PHP que saturan la IA)
infraestructura/wordpress_data/

# Bloquear datos internos del servidor de correo
infraestructura/correo/mail-data/
infraestructura/correo/mail-state/
infraestructura/correo/mail-logs/
infraestructura/correo/rainloop-data/

# Bloquear carpetas de base de datos
infraestructura/db_data/
infraestructura/vault_data/

# Bloquear archivos de sistema y temporales
.bash_history
.cache/
.local/
backups/